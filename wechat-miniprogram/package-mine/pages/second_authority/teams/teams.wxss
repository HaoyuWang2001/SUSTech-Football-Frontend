.check-btn {
  background-color: #3388d8; /* 按钮背景颜色 */
  color: white; /* 文字颜色 */
  padding: 5px 10px; /* 按钮内边距 */
  border: none; /* 去除按钮边框 */
  border-radius: 5px; /* 按钮圆角 */
  cursor: pointer; /* 鼠标样式 */
  margin-bottom: 20rpx;
  margin-right: 20rpx;
  font-size: small;
}

.delete-btn {
  background-color: #ff4d4f; /* 按钮背景颜色 */
  color: white; /* 文字颜色 */
  padding: 5px 10px; /* 按钮内边距 */
  border: none; /* 去除按钮边框 */
  border-radius: 5px; /* 按钮圆角 */
  cursor: pointer; /* 鼠标样式 */
  margin-right: 20rpx;
  font-size: small;
}

.function-image {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.1));
  transition: all 0.3s ease;
}

.function-button:active .function-image {
  transform: scale(0.95);
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.08));
}

.function-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  letter-spacing: 0.5rpx;
  transition: all 0.3s ease;
}

.function-button:active .function-text {
  color: rgb(237, 108, 0);
}

.function-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8f8f8 100%);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.05), 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  transition: all 0.3s ease;
  min-width: 160rpx;
  border: 1rpx solid rgba(237, 108, 0, 0.05);
}

.function-button:active {
  transform: translateY(4rpx) scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04), 0 1rpx 4rpx rgba(0, 0, 0, 0.02);
  background: linear-gradient(135deg, #f8f8f8 0%, #f0f0f0 100%);
  border-color: rgba(237, 108, 0, 0.15);
}

.function-container {
  display: flex;
  gap: 15rpx;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.hint-text {
  font-size: small;
  margin-bottom: 30rpx;
}