.check-btn {
  /* 橙色安全按钮 - 编辑操作 */
  background: linear-gradient(135deg, #ed6c00 0%, #ff8c32 100%);
  color: white;
  padding: 8rpx 24rpx;
  border: none;
  border-radius: 12rpx;
  cursor: pointer;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(237, 108, 0, 0.2);
  transition: all 0.3s cubic-bezier(0.2, 0.8, 0.3, 1);
  text-align: center;
}

.check-btn:active {
  background: linear-gradient(135deg, #cc5c00 0%, #e67a29 100%);
  box-shadow: 0 2rpx 6rpx rgba(237, 108, 0, 0.3);
  transform: translateY(2rpx);
}

.delete-btn {
  /* 红色危险按钮 - 删除操作 */
  background: linear-gradient(135deg, #ff6400 10%, #ff8c32 100%);
  color: white;
  padding: 8rpx 24rpx;
  border: none;
  border-radius: 12rpx;
  cursor: pointer;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(255, 100, 0, 0.2);
  transition: all 0.3s cubic-bezier(0.2, 0.8, 0.3, 1);
  text-align: center;
}

.delete-btn:active {
  background: linear-gradient(135deg, #cc5c00 0%, #e67a29 100%);
  box-shadow: 0 2rpx 6rpx rgba(255, 100, 0, 0.3);
  transform: translateY(2rpx);
}

.function-image {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.1));
  transition: all 0.3s ease;
}

.function-button:active .function-image {
  transform: scale(0.95);
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.08));
}

.function-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  letter-spacing: 0.5rpx;
  transition: all 0.3s ease;
}

.function-button:active .function-text {
  color: rgb(237, 108, 0);
}

.function-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8f8f8 100%);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.05), 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  transition: all 0.3s ease;
  min-width: 160rpx;
  border: 1rpx solid rgba(237, 108, 0, 0.05);
}

.function-button:active {
  transform: translateY(4rpx) scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04), 0 1rpx 4rpx rgba(0, 0, 0, 0.02);
  background: linear-gradient(135deg, #f8f8f8 0%, #f0f0f0 100%);
  border-color: rgba(237, 108, 0, 0.15);
}

.function-container {
  display: flex;
  gap: 15rpx;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.hint-text {
  margin-left: 20rpx;
  margin-bottom: 20rpx;
  font-size: small;
}