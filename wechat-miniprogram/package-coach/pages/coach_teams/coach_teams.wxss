.delete-btn {
  background-color: #ed6c00;
  color: white;
  padding: 4px 12px;
  border-radius: 5px;
  font-size: small;
  font-weight: 600;
}

.hint-text {
  margin-left: 20rpx;
  margin-bottom: 30rpx;
  font-size: small;
}

.block-container {
  padding: 30rpx 0 0 0;
  background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
  box-shadow:
    0 16rpx 32rpx rgba(0, 0, 0, 0.06),
    0 4rpx 12rpx rgba(0, 0, 0, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  overflow: hidden;
  border: 4rpx solid rgba(237, 108, 0, 0.08);
  transition: all 0.3s ease;
}

.block-main {
  padding: 20rpx 0rpx 40rpx 0rpx;
}

.no-info {
  margin: 40rpx 20rpx;
  font-size: 30rpx;
  color: #999;
  text-align: center;
  padding: 60rpx 40rpx;
  background: rgba(237, 108, 0, 0.03);
  border-radius: 20rpx;
  border: 1rpx dashed rgba(237, 108, 0, 0.2);
}