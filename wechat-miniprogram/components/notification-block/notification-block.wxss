/* components/notification-block.wxss */
.block-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #000000;
  letter-spacing: 0.5rpx;
  display: flex;
  flex-direction: row;
}

.notification-container {
  margin-bottom: 40rpx;
}

.notification-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(237, 108, 0, 0.1);
  background: transparent;
}

.red-dot {
  position: relative;
  left: -20rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #ff4d4f;
  margin-top: 18rpx;
}

.title-text {

}

.notification-box {
  background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
  border: 5rpx solid rgba(237, 108, 0, 0.08);
  border-radius: 0 0 24rpx 24rpx;
  overflow: hidden;
  transition: height 0.3s ease-in-out;
}

.invitation-item {
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(237, 108, 0, 0.05);
  transition: all 0.2s ease;
}

.invitation-item:active {
  background: rgba(237, 108, 0, 0.03);
}

.invitation-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
}

.icon {
  width: 60rpx;
  height: 60rpx;
  transition: transform 0.3s ease;
}

.icon-rotated {
  width: 60rpx;
  height: 60rpx;
  transform: rotate(180deg);
}

.hint-text {
  margin-left: 20rpx;
  margin-bottom: 30rpx;
  font-size: small;
}