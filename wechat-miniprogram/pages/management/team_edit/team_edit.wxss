/* pages/management/team_edit/team_edit.wxss */
.block-space {
  border-top: 1px solid rgb(202, 202, 202);
  margin-top: 20rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #cccccc;
  background-color: white;
}

.coach-op-panel{
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-right: 20rpx;
  gap: 20rpx;
  min-width: 100rpx;
}

.coach-op-btn{
  height: 48rpx;
  line-height: 48rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
  text-align: center;
  padding: 10rpx 26rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.coach-op-btn.danger{
  color: white;
  background: #ff373a;
}

.coach-op-btn.primary{
  color: white;
  background-color: #ed6c00;
}

.coach-op-btn:active{
  transform: scale(0.95);
  opacity: 0.8;
}

.player-card-list {
  max-height: 70vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.player-op-panel {
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-right: 20rpx;
  gap: 12rpx;
  min-width: 100rpx;
}

.player-op-btn{
  height: 48rpx;
  line-height: 48rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
  text-align: center;
  padding: 10rpx 26rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.player-op-btn.danger{
  color: white;
  background: #ff373a;
}

.player-op-btn.primary{
  color: white;
  background-color: #ed6c00;
}

.player-op-btn:active{
  transform: scale(0.95);
  opacity: 0.8;
}

.info-container {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 20rpx;
  width: 90%;
}

.teamname {
  font-size: medium;
  white-space: normal;
  word-wrap: break-word;
  flex-grow: 1;
}

.name-edit {
  font-size: small;
  color: gray;
  display: inline-block;
  border-bottom: 1px solid gray;
  margin-left: 3%;
  flex-shrink: 0;
}

.description-container {
  margin-top: 3%;
  margin-left: 3%;
}

.description-content {
  padding: 3%;
  margin-bottom: 5%;
}

.description {
  font-size: small;
  width: 100%;
  height: 80px;
  resize: none;
  overflow: auto;
}

.description-edit {
  display: inline-block;
  font-size: small;
  color: gray;
  border-bottom: 1px solid gray;
  margin-left: 3%;
}

.important-person {
  margin-bottom: 5%;
}

.team-container {
  width: 100%;
}

.teammate-container {
  margin-bottom: 5%;
}

.text {
  margin-right: auto;
  margin-top: 3%;
  margin-bottom: 3%;
}

.image {
  margin-left: auto;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.confirm-btn{
  border: none;
  border-radius: 20px;
  cursor: pointer;
  background-color: #eb6c00;
  color: white;
  font-size: medium;
  max-width: 40%;
  margin: 20rpx 0 60rpx 0;
}

.icon {
  width: 32rpx;
  height: 32rpx;
  margin: 0;
  padding: 0;
  border-radius: 0;
}

.icon_retire {
  background-color: rgb(197, 209, 24);
}

.icon_rehire {
  background-color: rgb(201, 107, 209);
}

.player-number {
  font-size: small;
  color: rgb(102, 98, 98);
}

.player-name {
  font-size: small;
  max-width: 120rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.player-avatar {
  width: 50rpx;
  min-width: 50rpx;
  max-width: 50rpx;
  height: 50rpx;
  border-radius: 20rpx;
}

modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.1);
}

.modal-content {
  background-color: #fff;
}

input {
  display: block;
  width: 90%;
  margin-bottom: 10px;
  padding: 10px;
  border: 1px solid #ddd;
  border-radius: 5px;
}

.hint-text {
  margin-left: 20rpx;
  margin-bottom: 10rpx;
  font-size: small;
}

