/*pages/management/event_edit/event_teams/event_teams.wxss*/
/* 使用橙色系颜色设计系统 */
@import '../../../../styles/mixins.wxss';

.group-name {
  margin-top: 3%;
  margin-bottom: 3%;
  margin-left: 3%;
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.team-op-panel{
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-top: 6rpx;
  gap: 10rpx;
  min-width: 100rpx;
}

.team-op-btn{
  height: 48rpx;
  line-height: 48rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
  text-align: center;
  padding: 0 16rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.team-op-btn.danger{
  background: rgba(255,77,79,0.12);
  color: #ff4d4f;
}

.team-op-btn.primary{
  background: rgba(24,144,255,0.12);
  color: #1890ff;
}

.team-op-btn.success{
  background: rgba(82,196,26,0.12);
  color: #52c41a;
}

.team-op-btn:active{
  transform: scale(0.95);
  opacity: 0.8;
}

