/* pages/pub/match/match_referee/match_referee.wxss */
@import '../../../../styles/tables.wxss';

.button-update {
  padding: 10rpx 40rpx;
  color: white;
  background-color: #ed6c00;
  font-weight: bold;
  border-radius: 20rpx;
}

/* 球员表格相关 */
.grid-container {
  margin: 20rpx 0;
  display: grid;
  grid-template-columns: 1fr 1fr 2fr 1fr;
  gap: 10rpx 0;
  justify-items: center;
  align-items: center;
}

/* 球员表格相关 */
.grid-header {
  width: 100%;
  height: 100%;
  font-weight: bold;
}

/* 球员表格相关 */
.grid-item {
  padding: 0 0;
  text-align: center;
  font-size: smaller;
}

/* 球员表格相关 */
.player-avatar {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
}

.button-update-playerList {
  padding: 10rpx 20rpx;
  margin: 0 10rpx;
  color: white;
  background-color: #ed6c00;
  font-weight: bold;
  border-radius: 20rpx;
}

.button-delete-action {
  background-color: red;
  color: white;
  font-size: small;
}

/* pages/yourPage/yourPage.wxss */
.input-container {
  display: flex;
  flex-direction: column;
  padding: 10rpx;
}

.input-item {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.input-item text {
  flex-shrink: 0;
  margin-right: 10px;
  color: black;
}

.input-item input, .input-item picker {
  flex-grow: 1;
  padding: 5px 10px;
  border: 1px solid #ccc;
  border-radius: 5px;
}

/* circle-component.wxss */
.process-container {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 60rpx 0;
}

.stage-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.line {
  width: 80rpx;
  height: 10rpx;
  margin: 0 40rpx;
}

.orange {
  background-color: #ed6c00;
}

.gray {
  background-color: #8a8a8a;
}

.stage-icon {
  width: 80rpx;
  height: 80rpx;
}

.videoOrLive {
  display: inline-block;
  width: 60%;
}

/* 直播或回放按钮的样式 */
.videoOrLive_goto {
  margin-left: 20rpx;
  background-color: rgb(237, 108, 0);
  color: white;
  font-weight: normal;
  padding: 10rpx 20rpx;
}

.videoOrLive_delete {
  margin-left: 20rpx;
  background-color: red;
  color: white;
  font-weight: normal;
  padding: 10rpx 20rpx;
}

.hint-text {
  font-size: small;
  margin-left: 20rpx;
  margin-bottom: 30rpx;
}

/* 比赛进球布局 */
.score-card {
  background: linear-gradient(90deg, #ed6c00 0%, #ff8c32 100%);
  border: 1px solid #f3d8be;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.score-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.team-name {
  flex: 1;
  font-weight: bold;
  font-size: 34rpx;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-left: 20rpx;
}

.score-box {
  flex: 0 0 160rpx;
  background: #ffffff;
  border: 1px solid #f0e2d4;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.score-label {
  color: #666;
  font-size: 32rpx;
}

.score-number {
  font-weight: 700;
  color: #ed6c00;
  font-size: 32rpx;
}

.score-divider {
  height: 1px;
  background: #ffffff;
}

/* 比赛事件表格（复用公共表格样式） */
.cell.time {
  flex: 1.2;
}

.cell.team {
  flex: 2;
}

.cell.player {
  flex: 2.4;
}

.cell.action {
  flex: 1;
  color: #ed6c00;
  font-weight: 600;
}

.cell.ops {
  flex: 1.5;
  justify-content: center;
}

.delete-btn {
  max-width: 100rpx;
  padding: 8rpx 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(255, 68, 68, 0.2);
  transition: all 0.3s cubic-bezier(0.2, 0.8, 0.3, 1);
  text-align: center;
  border-radius: 12rpx;
  color: white;
  background: linear-gradient(135deg, #ff4444 10%, #ff8c32 100%);
}

.empty-state {
  padding: 24rpx;
  color: #777;
  text-align: center;
}