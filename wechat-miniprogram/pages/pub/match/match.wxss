/* 空状态提示 */
.empty-state {
  text-align: center;
  padding: 48rpx 32rpx;
  color: #999999;
  font-size: 28rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
  border-radius: 16rpx;
  border: 2rpx dashed rgba(237, 108, 0, 0.12);
  margin: 20rpx;
}

/* 比赛赛况子选项卡 */
.subtabs {
  display: flex;
  margin: 0 20rpx 20rpx 20rpx;
  border: 2rpx solid rgba(237, 108, 0, 0.12);
  border-radius: 20rpx;
  overflow: hidden;
}

.subtab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  color: #666;
  background: #fff;
  transition: all 0.2s ease;
  font-size: 30rpx;
}

.subtab.active {
  color: #ed6c00;
  font-weight: 700;
  background: rgba(237, 108, 0, 0.08);
}

.lineup-columns {
  display: flex;
  gap: 20rpx;
}

.lineup-column {
  flex: 1;
  background: #ffffff;
  border: 2rpx solid rgba(237, 108, 0, 0.12);
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(237, 108, 0, 0.08);
}

.lineup-title {
  font-weight: 700;
  font-size: 30rpx;
  margin-bottom: 16rpx;
  color: #333;
}

.lineup-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(237, 108, 0, 0.08);
}

.lineup-item:last-child {
  border-bottom: none;
}

.lineup-number {
  width: 80rpx;
  color: #ed6c00;
  font-weight: 700;
}

.lineup-name {
  flex: 1;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ============================================================================
 * 评论区域样式（已禁用）
 * ============================================================================ */

.comment-container {
  display: flex;
  margin-top: 30rpx;
}

.input-container {
  display: flex;
  align-items: center;
  padding: 10rpx 50rpx;
  border: 2rpx solid rgba(237, 108, 0, 0.3);
  border-radius: 20rpx;
  background-color: #f9f9f9;
  height: 80rpx;
  margin-right: 5%;
  transition: all 0.3s ease;
}

.input-container:focus-within {
  border-color: rgba(237, 108, 0, 0.5);
  box-shadow: 0 0 0 4rpx rgba(237, 108, 0, 0.1);
}

.input-container .input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333333;
}

.button {
  align-self: center;
  height: 90%;
  max-width: 130rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: white;
  background: linear-gradient(90deg, #ed6c00 0%, #ff8c32 100%);
  border: none;
  border-radius: 16rpx;
  padding: 0 20rpx;
  line-height: 80rpx;
  box-shadow: 0 4rpx 12rpx rgba(237, 108, 0, 0.2);
  transition: all 0.3s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.button:active {
  background: linear-gradient(90deg, #db6300 0%, #e86700 100%);
  box-shadow: 0 2rpx 8rpx rgba(237, 108, 0, 0.15);
  transform: translateY(2rpx);
}

/* ============================================================================
 * 响应式设计
 * ============================================================================ */

@media (max-width: 600rpx) {
  /* 块容器响应式 */
  .block-container {
    margin: 16rpx 16rpx;
    padding: 24rpx 20rpx;
  }

  .block-title {
    font-size: 30rpx;
  }

  .block-more {
    font-size: 24rpx;
    padding: 6rpx 12rpx;
  }

  .block-main {
    font-size: 26rpx;
  }

  /* 选项卡响应式 */
  .tabs {
    margin: 16rpx 16rpx 0 16rpx;
  }

  .tab {
    padding: 20rpx 0;
  }

  .tab-text {
    font-size: 26rpx;
  }

  .tab-content {
    padding: 0 16rpx 32rpx 16rpx;
  }

  /* 按钮响应式 */
  .videoOrLive {
    padding: 20rpx 24rpx;
    font-size: 26rpx;
  }

  .button-update {
    padding: 10rpx 20rpx;
    font-size: 24rpx;
  }

  .timeline-team-tag {
    font-size: 20rpx;
    padding: 6rpx 12rpx;
  }

  .timeline-item {
    min-height: 118rpx;
    margin-bottom: 16rpx;
  }

  .timeline-milestone {
    padding: 8rpx 22rpx;
    font-size: 22rpx;
  }

  .timeline-side-left {
    padding-right: 14rpx;
  }

  .timeline-side-right {
    padding-left: 14rpx;
  }

  .timeline-minute-node {
    width: 66rpx;
    height: 66rpx;
  }

  .timeline-minute-text {
    font-size: 20rpx;
  }

  .timeline-card {
    border-radius: 14rpx;
    padding: 12rpx 12rpx;
  }

  .timeline-action-text {
    font-size: 22rpx;
  }

  .timeline-action-icon {
    font-size: 22rpx;
    margin-right: 4rpx;
  }

  .timeline-action-card {
    width: 12rpx;
    height: 20rpx;
    margin-right: 6rpx;
  }

  .timeline-player {
    font-size: 24rpx;
  }

  .timeline-sub-player {
    font-size: 24rpx;
  }

  /* 收藏按钮响应式 */
  .favorite-button {
    width: 56rpx;
    height: 56rpx;
  }

  .favorite-icon {
    width: 36rpx;
    height: 36rpx;
  }
}
