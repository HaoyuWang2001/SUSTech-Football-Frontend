/* pages/pub/match/match.wxss - 现代化设计 (使用橙色系颜色设计系统) */
@import '../../../styles/mixins.wxss';
@import '../../../styles/tables.wxss';

/* ============================================================================
 * 页面头部区域
 * ============================================================================ */

.section-header {
  background-color: #ffffff;
  padding: 20rpx 0 40rpx 0;
  box-shadow: 0 4rpx 24rpx rgba(237, 108, 0, 0.1);
  position: relative;
  margin-bottom: 20rpx;
}

.buttons {
  margin: 10rpx 20rpx;
  text-align: right;
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  align-items: center;
  padding: 0 20rpx;
  position: relative;
  z-index: 10;
}

/* 收藏按钮现代化 */
.favorite-button {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: rgba(237, 108, 0, 0.08);
  border: 2rpx solid rgba(237, 108, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.favorite-button:active {
  transform: scale(0.95);
  background-color: rgba(237, 108, 0, 0.15);
  border-color: rgba(237, 108, 0, 0.25);
}

.favorite-icon {
  width: 40rpx;
  height: 40rpx;
  transition: all 0.3s ease;
}

.favorite-button:active .favorite-icon {
  transform: scale(0.9);
}

/* ============================================================================
 * 现代化块容器
 * ============================================================================ */

.block-container {
  /* 基础卡片样式 */
  margin: 24rpx 20rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
  border-radius: 24rpx;
  border: 2rpx solid rgba(237, 108, 0, 0.12);
  box-shadow:
    0 4rpx 24rpx rgba(237, 108, 0, 0.1),
    0 2rpx 12rpx rgba(237, 108, 0, 0.08);
  padding: 32rpx;
  position: relative;
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.2, 0.8, 0.3, 1);
}

/* 块容器顶部装饰条 */
.block-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #ed6c00 0%, #ff8c32 100%);
  border-radius: 24rpx 24rpx 0 0;
}

.block-container:active {
  transform: translateY(4rpx) scale(0.995);
  box-shadow:
    0 2rpx 12rpx rgba(237, 108, 0, 0.08),
    0 1rpx 6rpx rgba(237, 108, 0, 0.06);
  border-color: rgba(237, 108, 0, 0.25);
}

/* 块头部 */
.block-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(237, 108, 0, 0.08);
}

.block-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  flex: 1;
}

.block-more {
  font-size: 26rpx;
  color: #ed6c00;
  font-weight: 500;
  padding: 8rpx 16rpx;
  background-color: rgba(237, 108, 0, 0.08);
  border-radius: 12rpx;
  border: 1rpx solid rgba(237, 108, 0, 0.15);
  transition: all 0.3s ease;
}

.block-more:active {
  background-color: rgba(237, 108, 0, 0.15);
  border-color: rgba(237, 108, 0, 0.25);
  transform: translateY(2rpx);
}

/* 块主要内容 */
.block-main {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.5;
}

/* ============================================================================
 * 现代化选项卡
 * ============================================================================ */

.tabs {
  display: flex;
  justify-content: space-around;
  background-color: #ffffff;
  padding: 0;
  margin: 20rpx 20rpx 0 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(237, 108, 0, 0.12);
  box-shadow: 0 4rpx 24rpx rgba(237, 108, 0, 0.1);
}

.tab {
  flex-grow: 1;
  text-align: center;
  padding: 28rpx 0;
  color: #666666;
  position: relative;
  transition: all 0.3s ease;
}

.tab-text {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  transition: color 0.3s ease;
}

.tab.active .tab-text {
  color: #ed6c00;
  font-weight: 700;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 6rpx;
  background: linear-gradient(90deg, #ed6c00 0%, #ff8c32 100%);
  border-radius: 3rpx;
  opacity: 0;
  transform: scaleX(0.8);
  transition: all 0.3s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.tab.active .tab-indicator {
  opacity: 1;
  transform: scaleX(1);
}

.tab-content {
  padding: 20rpx 0;
}

/* ============================================================================
 * 现代化按钮样式
 * ============================================================================ */

/* 直播/回放按钮现代化 */
.videoOrLive {
  /* 基础样式 */
  background: linear-gradient(90deg, #ed6c00 0%, #ff8c32 100%);
  border: none;
  border-radius: 24rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  padding: 24rpx 32rpx;
  margin-bottom: 20rpx;
  width: 100%;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(237, 108, 0, 0.2);
  transition: all 0.3s cubic-bezier(0.2, 0.8, 0.3, 1);
  position: relative;
  overflow: hidden;
}

.videoOrLive::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #ff8c32 0%, #ffb366 100%);
  border-radius: 24rpx 24rpx 0 0;
}

.videoOrLive:active {
  background: linear-gradient(90deg, #db6300 0%, #e86700 100%);
  box-shadow: 0 2rpx 8rpx rgba(237, 108, 0, 0.15);
  transform: translateY(2rpx);
}

/* 裁判页面按钮现代化 */
.button-update {
  background: linear-gradient(90deg, #ed6c00 0%, #ff8c32 100%);
  border: none;
  border-radius: 24rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 12rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(237, 108, 0, 0.2);
  transition: all 0.3s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.button-update:active {
  background: linear-gradient(90deg, #db6300 0%, #e86700 100%);
  box-shadow: 0 2rpx 8rpx rgba(237, 108, 0, 0.15);
  transform: translateY(2rpx);
}

.timeline-team-tag {
  font-size: 22rpx;
  color: #ed6c00;
  font-weight: 600;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(237, 108, 0, 0.1);
  border: 1rpx solid rgba(237, 108, 0, 0.18);
}

.timeline-list {
  position: relative;
  padding: 8rpx 0;
}

.timeline-list::before {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 4rpx;
  transform: translateX(-50%);
  background: linear-gradient(180deg, #2dbd5f 0%, #26a452 100%);
  border-radius: 999rpx;
}

.timeline-item {
  display: flex;
  align-items: center;
  min-height: 132rpx;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.timeline-item:last-child {
  margin-bottom: 0;
}

.timeline-side {
  width: 42%;
  min-height: 1rpx;
  display: flex;
}

