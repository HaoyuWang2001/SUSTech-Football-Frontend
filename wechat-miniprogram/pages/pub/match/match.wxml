<view class="section-header">
  <match status="{{status}}" team1="{{homeTeam.name}}" team2="{{awayTeam.name}}" icon1="{{homeTeam.logoUrl}}" icon2="{{awayTeam.logoUrl}}" score1="{{homeTeam.score}}" score2="{{awayTeam.score}}" penalty1="{{homeTeam.penalty}}" penalty2="{{awayTeam.penalty}}" time="{{strTime}}" hasBegun="{{hasBegun}}" has_button="{{true}}">
    <view wx:if="{{!favorited}}" class="favorite-button" bind:tap="favorite">
      <image class="favorite-icon" src="/assets/unfavorited.png" mode="scaleToFill" />
    </view>
    <view wx:if="{{favorited}}" class="favorite-button" bind:tap="unfavorite">
      <image class="favorite-icon" src="/assets/favorited.png" mode="scaleToFill" />
    </view>
  </match>
</view>

<view class="block-container" wx:if="{{isReferee}}">
  <view class="block-top">
    <text class="block-title">更新比赛信息</text>
    <text class="button-update" bind:tap="gotoMatchRefereePage">裁判页面</text>
  </view>
  <view class="block-main">
    <text>您的身份为本场比赛的管理员或裁判，可通过“裁判页面”按钮，进入裁判页面，对比赛信息进行更改。</text>
  </view>
</view>

<view class="tabs">
  <view class="tab {{activeIndex==0?'active':''}}" data-index="0" bindtap="switchTab">
    <text class="tab-text">基本信息</text>
    <view class="tab-indicator {{activeIndex==0?'active':''}}"></view>
  </view>
  <view class="tab {{activeIndex==1?'active':''}}" data-index="1" bindtap="switchTab">
    <text class="tab-text">直播/回放</text>
    <view class="tab-indicator {{activeIndex==1?'active':''}}"></view>
  </view>
  <view class="tab {{activeIndex==2?'active':''}}" data-index="2" bindtap="switchTab">
    <text class="tab-text">比赛赛况</text>
    <view class="tab-indicator {{activeIndex==2?'active':''}}"></view>
  </view>
</view>

<view class="tab-content">
  <view wx:if="{{activeIndex == 0}}">
    <view class="block-container">
      <view class="block-top">
        <text class="block-title">赛事</text>
        <text class="block-more"></text>
      </view>
      <view class="block-main">
        {{matchEvent.eventName}}
      </view>
      <block wx:if="{{matchEvent.stage != null}}">
        <view class="block-top" style="margin-top: 20rpx;">
          <text class="block-title">比赛阶段</text>
          <text class="block-more"></text>
        </view>
        <view class="block-main">
          {{matchEvent.stage}} - {{matchEvent.tag}}
        </view>
      </block>
    </view>
    <view class="block-container">
      <view class="block-top">
        <text class="block-title">比赛时间</text>
        <text class="block-more"></text>
      </view>
      <view class="block-main">
        {{strTime}}
      </view>
    </view>
    <view class="block-container" wx:if="{{description}}">
      <view class="block-top">
        <text class="block-title">比赛描述</text>
        <text class="block-more"></text>
      </view>
      <view class="block-main">
        {{description}}
      </view>
    </view>


