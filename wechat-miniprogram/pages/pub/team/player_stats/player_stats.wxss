/* pages/pub/team/player_stats/player_stats.wxss */
@import '../../../../styles/mixins.wxss';

/* 基础容器 - 减少padding以增加表格宽度 */
.container {
  padding: 20rpx;
  background-color: #f2f2f2;
  min-height: 100vh;
}

.table-container {
  /* 减少padding，让表格更接近页面边缘 */
  padding: 10rpx;
  box-sizing: border-box;
}

/* 表格容器 */
.player-stats-table {
  width: 100%;
  border-collapse: collapse;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(237, 108, 0, 0.08);
}

/* 表格行 - 使用flex布局避免冲突 */
.player-stats-row {
  display: flex;
  border-bottom: 1rpx solid rgba(237, 108, 0, 0.08);
}

/* 表头行 */
.player-stats-header {
  background: linear-gradient(90deg, #ed6c00 0%, #ff8c32 100%);
  color: #ffffff;
  font-weight: 600;
  border-bottom: none;
}

/* 基础单元格 */
.player-stats-cell {
  flex: 1;
  padding: 20rpx 8rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666666;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
}

/* 号码列 - 较小宽度 */
.cell-number-column {
  flex: 0.5;
  max-width: 80rpx;
  min-width: 60rpx;
}

/* 球员列 - 特殊宽度和对齐 */
.cell-player-column {
  flex: 2;
  max-width: 300rpx;
  justify-content: flex-start; /* 球员列左对齐 */
  padding-left: 16rpx;
  text-align: left;
}

/* 球员信息容器 */
.player-info {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 16rpx;
  width: 100%;
}

.player-avatar {
  width: 50rpx;
  min-width: 50rpx;
  max-width: 50rpx;
  height: 50rpx;
  border-radius: 20rpx;
}

.player-name {
  /* 球员名字最大宽度，防止挤压其他列 */
  max-width: 200rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 移除最后一行边框 */
.player-stats-row:last-child {
  border-bottom: none;
}

/* 颜色覆盖 - 确保表头颜色正确 */
.player-stats-header .player-stats-cell {
  color: #ffffff !important;
}

/* 响应式设计 - 移动端适配 */
@media (max-width: 600rpx) {
  .player-stats-cell {
    padding: 16rpx 4rpx;
    font-size: 24rpx;
  }

  .cell-player-column {
    flex: 1.5;
    max-width: 200rpx;
  }

  .cell-number-column {
    flex: 0.4;
    max-width: 60rpx;
    min-width: 50rpx;
  }

  .player-avatar {
    width: 40rpx;
    height: 40rpx;
  }

  .player-name {
    max-width: 150rpx;
  }
}