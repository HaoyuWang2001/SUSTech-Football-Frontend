/* pages/pub/team/player_stats/player_stats.wxss */
@import '../../../../styles/mixins.wxss';
@import '../../../../styles/tables.wxss';

/* 基础容器 - 减少padding以增加表格宽度 */
.container {
  padding: 20rpx 0;
  background-color: #ffffff;
  min-height: 100vh;
}

.table-container {
  width: 95%;
  padding: 0;
  box-sizing: border-box;
}

.fancy-table {
	background-color: #ffffff;
	border: 1rpx solid rgba(237, 108, 0, 0.1);
	border-radius: 16rpx;
	overflow: hidden;
}

.fancy-table .row {
	background-color: #ffffff;
}

.fancy-table .row:nth-child(odd):not(.header) {
	background-color: #fff8f1;
}

.row {
  display: flex;
  align-items: center;      /* 垂直居中 */
  max-height: 80rpx;        /* 控制行高 */
  border-bottom: 1rpx solid #eee;
}

.header .cell-player-column {
  justify-content: center;
}

.cell {
  flex: 1;
  display: flex;
  justify-content: center;  /* 水平居中 */
  align-items: center;      /* 垂直居中 */
  text-align: center;
  padding: 10rpx 0;
  font-size: 26rpx;
}

.stat-cell {
	font-weight: 700;
	color: #333333;
}

.stat-cell.warning {
	color: #c28a00;
}

.stat-cell.danger {
	color: #d84a4a;
}

/* 球员列 */
.cell-player-column-header {
  flex: 2.5;
  justify-content: center;
}

.cell-player-column {
  flex: 2.5;
  justify-content: center;
}

.player-info {
  margin-left: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.player-avatar {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
}


/* 响应式设计 - 移动端适配 */
@media (max-width: 600rpx) {
  .container {
    padding: 12rpx; /* 添加容器padding调整 */
  }

}