/* pages/pub/event_team/event_team.wxss */
@import '../../../styles/mixins.wxss';
@import '../../../styles/tables.wxss';

page {
	background-color: #f2f2f2;
	min-height: 100vh;
}

.section-header {
	background-color: #ffffff; /* Colors.white */
  padding: 20rpx 0 40rpx 0;
  box-shadow: 0 4rpx 24rpx rgba(237, 108, 0, 0.1); /* Shadows.card */
}

.primary-button {
	padding: 16rpx 0rpx;
	background: linear-gradient(135deg, #ed6c00 0%, #ff8c32 100%);
	border-radius: 20rpx;
	color: #ffffff;
	font-size: 26rpx;
	font-weight: 700;
	box-shadow: 0 4rpx 16rpx rgba(237, 108, 0, 0.25);
	text-align: center;
	min-width: 160rpx;
}

.primary-button:active {
	transform: translateY(4rpx) scale(0.98);
	box-shadow: 0 2rpx 8rpx rgba(237, 108, 0, 0.15);
}

.primary-button-text {
	letter-spacing: 2rpx;
}

.tabs {
	display: flex;
	justify-content: space-around;
	background-color: #ffffff;
	padding: 0;
	margin: 20rpx 20rpx 0 20rpx;
	border-radius: 24rpx;
	border: 2rpx solid rgba(237, 108, 0, 0.12);
	box-shadow: 0 4rpx 24rpx rgba(237, 108, 0, 0.1);
}

.tab {
	flex-grow: 1;
	text-align: center;
	padding: 28rpx 0;
	color: #666666;
	position: relative;
	transition: all 0.3s ease;
}

.tab.active .tab-text {
	color: #ed6c00;
	font-weight: 700;
}

.tab-indicator {
	position: absolute;
	bottom: 0;
	left: 24rpx;
	right: 24rpx;
	height: 6rpx;
	background: linear-gradient(90deg, #ed6c00 0%, #ff8c32 100%);
	border-radius: 3rpx;
	opacity: 0;
	transform: scaleX(0.8);
	transition: all 0.3s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.tab.active .tab-indicator {
	opacity: 1;
	transform: scaleX(1);
}

.tab-content {
  margin-top: 0;
	padding: 20rpx 20rpx 32rpx 20rpx;
}

.block-container {
	margin-bottom: 24rpx;
}

.block-top {
	margin-bottom: 20rpx;
}

.block-title {
	font-size: 32rpx;
	font-weight: 600;
}

.block-more {
  font-size: 24rpx; /* Tokens.fontSizeSmall */
  color: #ed6c00; /* Colors.primary */
  text-decoration: underline;
}

.block-subtitle {
	font-size: 24rpx;
	color: #888888;
}

.block-main {
	padding: 0 8rpx;
}

.fancy-table {
	background-color: #ffffff;
	border: 1rpx solid rgba(237, 108, 0, 0.1);
	border-radius: 16rpx;
	overflow: hidden;
}

.fancy-table .row {
	background-color: #ffffff;
}

.fancy-table .row:nth-child(odd):not(.header) {
	background-color: #fff8f1;
}

.row {
  display: flex;
  align-items: center;      /* 垂直居中 */
  max-height: 80rpx;        /* 控制行高 */
  border-bottom: 1rpx solid #eee;
}

.header .cell-player-column {
  justify-content: center;
}

.cell {
  flex: 1;
  display: flex;
  justify-content: center;  /* 水平居中 */
  align-items: center;      /* 垂直居中 */
  text-align: center;
  padding: 10rpx 0;
  font-size: 26rpx;
}

.stat-cell {
	font-weight: 700;
	color: #333333;
}

.stat-cell.warning {
	color: #c28a00;
}

.stat-cell.danger {
	color: #d84a4a;
}

/* 球员列 */
.cell-player-column-header {
  flex: 2.5;
  justify-content: center;
}

.cell-player-column {
  flex: 2.5;
  justify-content: center;
}

.player-info {
  margin-left: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.player-avatar {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
}

.scroll-container {
	display: flex;
	flex-direction: row;
	white-space: nowrap;
	padding-bottom: 20rpx;
}

.empty-state {
	padding: 40rpx 0;
	text-align: center;
	color: #999999;
	font-size: 26rpx;
}

.empty-text {
	color: #999999;
}

.player-avatar {
	border: 2rpx solid rgba(237, 108, 0, 0.1);
	box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

@media (max-width: 600rpx) {
	.tabs {
		margin: 0 12rpx 16rpx 12rpx;
	}

	.tab-content {
		padding: 0 12rpx 16rpx 12rpx;
	}

	.block-container {
		padding: 20rpx 16rpx;
	}
}